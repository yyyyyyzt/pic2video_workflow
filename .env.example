# ============================================================================
# ScailSwap 配置（复制为 .env 后按需修改：cp .env.example .env）
# ============================================================================

# 生成引擎：comfyui（默认，自托管，支持长视频锚定）| fal（托管 API，仅短片）| fake（调试）
SCAILSWAP_ENGINE=comfyui

# 数据目录（上传、任务状态、分块中间文件、输出）
SCAILSWAP_DATA_DIR=./data

# ---------------------------------------------------------------------------
# 自托管 ComfyUI（主引擎）
# ---------------------------------------------------------------------------
COMFYUI_URL=http://127.0.0.1:8188
# 单块推理轮询超时（秒）
COMFYUI_CHUNK_TIMEOUT=1800

# 模型文件名（与 setup.sh --with-comfyui 下载的文件对应；换 fp8 变体在此修改）
SCAILSWAP_UNET=wan2.1_14B_SCAIL_2_fp16.safetensors
# 显存 <32GB 建议：SCAILSWAP_UNET=wan2.1_14B_SCAIL_2_fp8_scaled.safetensors
SCAILSWAP_TEXT_ENCODER=umt5_xxl_fp8_e4m3fn_scaled.safetensors
SCAILSWAP_VAE=wan_2.1_vae.safetensors
SCAILSWAP_CLIP_VISION=clip_vision_h.safetensors
SCAILSWAP_LORA_LIGHTX2V=lightx2v_I2V_14B_480p_cfg_step_distill_rank64_bf16.safetensors
SCAILSWAP_LORA_DPO=wan2.1_SCAIL_2_DPO_lora_bf16.safetensors
SCAILSWAP_SAM3_CKPT=sam3.1_multiplex_fp16.safetensors

# ---------------------------------------------------------------------------
# fal.ai 托管 API（可选，仅 ≤81 帧短片验证；不支持长视频锚定）
# ---------------------------------------------------------------------------
# FAL_KEY=your-fal-api-key

# ---------------------------------------------------------------------------
# Wav2Lip 口型精修（可选后处理，setup.sh --with-wav2lip 安装）
# ---------------------------------------------------------------------------
# WAV2LIP_DIR=./Wav2Lip
# WAV2LIP_CHECKPOINT=./Wav2Lip/checkpoints/wav2lip_gan.pth

# ---------------------------------------------------------------------------
# API 服务
# ---------------------------------------------------------------------------
SCAILSWAP_HOST=0.0.0.0
SCAILSWAP_PORT=8000

# ===========================================================================
# ↓↓↓ 以下为 legacy（roleswap 远程工作流封装，已被上方新架构取代）↓↓↓
# ===========================================================================
# ROLESWAP_BASE_URL=https://your-comfy-host.example.com
# ROLESWAP_WORKFLOW_ID=K11-SCAIL2动作迁移-角色替换-支持长视频-像素幻想Lab
# ROLESWAP_API_KEY=
