# ============================================================================
# RoleSwap 数字人长视频生成 API 配置
# 复制此文件为 .env 并填入你的真实配置：  cp .env.example .env
# ============================================================================

# 推理服务的 Base URL（例如 https://your-comfy-host.com）
ROLESWAP_BASE_URL=https://your-comfy-host.example.com

# 工作流 ID（换脸 / 角色替换工作流）
ROLESWAP_WORKFLOW_ID=K11-SCAIL2动作迁移-角色替换-支持长视频-像素幻想Lab

# 可选：鉴权 Token / API Key（若服务需要鉴权，会以 Bearer 方式带上）
ROLESWAP_API_KEY=

# 可选：单个片段结果轮询超时时间（秒），默认 600
ROLESWAP_RESULT_TIMEOUT=600

# 可选：轮询间隔（秒），默认 5
ROLESWAP_POLL_INTERVAL=5

# 可选：HTTP 请求超时时间（秒），默认 120
ROLESWAP_HTTP_TIMEOUT=120

# 本地文件输入方式（推荐 base64，API 原生支持，可避免上传端点 405）
# 可选值：base64 | upload | auto（先上传，405 时自动回退 base64）
ROLESWAP_INPUT_MODE=base64

# base64 模式下单文件最大字节数（默认 80MB）
ROLESWAP_MAX_BASE64_BYTES=83886080

# 提交任务超时（秒），base64 大 JSON 建议 600+
ROLESWAP_SUBMIT_TIMEOUT=600

# 开启详细诊断日志（写入 worker.log 与 stderr）
ROLESWAP_DEBUG=1

# 可选：自定义上传/查看端点
# ROLESWAP_UPLOAD_PATH=/api/comfy/upload/image
# ROLESWAP_VIEW_PATH=/api/comfy/view

# ---------------------------------------------------------------------------
# Web 测试页面（可选）
# ---------------------------------------------------------------------------
# 监听地址与端口
ROLESWAP_WEB_HOST=0.0.0.0
ROLESWAP_WEB_PORT=7860
# gunicorn worker 数（长视频任务建议保持 1，避免多进程任务状态丢失）
ROLESWAP_WEB_WORKERS=1
